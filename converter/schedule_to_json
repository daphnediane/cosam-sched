use v5.38.0;
use utf8;
use warnings;

use FindBin qw{ $RealBin };
use lib "${RealBin}/lib";
use lib "${RealBin}/../local/lib/perl5";

use Getopt::Long qw{ GetOptions };
use JSON         qw{ encode_json };
use File::Slurp  qw{ write_file };

use Convert::Workbook qw{};
use Convert::Rooms    qw{};
use Convert::Types    qw{};
use Convert::Events   qw{};

my $input_file;
my $output_file = 'schedule.json';
my $title       = '';
my $help        = 0;
my $config_file = '';
my $schedule_table = 'Schedule';
my $roommap_table  = 'RoomMap';
my $prefix_table   = 'Prefix';
my $staff_mode     = 0;

GetOptions(
    'input|i=s'           => \$input_file,
    'output|o=s'          => \$output_file,
    'title|t=s'           => \$title,
    'config|c=s'          => \$config_file,
    'schedule-table=s'    => \$schedule_table,
    'roommap-table=s'     => \$roommap_table,
    'prefix-table=s'      => \$prefix_table,
    'staff'               => \$staff_mode,
    'help|h'              => \$help,
) or die "Error in command line arguments\n";

if ( $help || !defined $input_file ) {
    say q{Usage: schedule_to_json --input <file.xlsx|google_sheets_url> [options]};
    say q{Options:};
    say q{  --output <file>          Output JSON file (default: schedule.json)};
    say q{  --title <string>          Event title};
    say q{  --config <file.yaml>      YAML file with Google Sheets API configuration};
    say q{  --schedule-table <name>  Table/sheet name for schedule data (default: Schedule)};
    say q{  --roommap-table <name>    Table/sheet name for room mapping (default: RoomMap)};
    say q{  --prefix-table <name>     Table/sheet name for panel type prefixes (default: Prefix)};
    say q{  --staff                   Include staff-only/private events in output};
    say q{  --help                    Show this help message};
    exit( $help ? 0 : 1 );
}

say "Reading: ${input_file}";

# Load configuration if provided
my $config = {};
if ($config_file) {
    die "Config file not found: ${config_file}\n" unless -f $config_file;
    $config->{config_file} = $config_file;
    say "Using config file: ${config_file}";
}

my $wb = Convert::Workbook::open_workbook( $input_file, $config );
die "Unable to open: ${input_file}\n" unless defined $wb;

# Create lookup configuration
my $lookup_config = {
    schedule_table => $schedule_table,
    roommap_table  => $roommap_table,
    prefix_table   => $prefix_table,
};

say "Reading schedule data from: ${input_file}";
my $rooms = Convert::Rooms::read_rooms( $wb, $lookup_config );
say 'Rooms: ', scalar @{ $rooms };

my ( $panel_types, $time_types ) = Convert::Types::read_panel_types( $wb, $lookup_config );
say 'Panel types: ', scalar @{ $panel_types };
say 'Time types: ', scalar @{ $time_types } if $time_types;

my ( $events, $presenters ) = Convert::Events::read_events( $wb, $rooms, $panel_types, $lookup_config, $staff_mode );
say 'Events: ', scalar @{ $events };
say 'Presenters: ', scalar @{ $presenters };

# Generate timeline entries from split events
my @timeline;
my @split_time_types;
my @filtered_panel_types;

# Process time types and create timeline entries
if ( $time_types && @$time_types ) {
    @split_time_types = @$time_types;
    
    # Filter out split panel types
    @filtered_panel_types = grep { 
        my $prefix = $_->{ prefix };
        !( $prefix eq 'SPLIT' || $prefix =~ m{\A SP}xms || $prefix =~ m{\A SPLIT}xms )
    } @$panel_types;
} else {
    # Legacy mode: find split panel types and convert them
    @filtered_panel_types = @$panel_types;
    
    my @split_panel_types = grep { 
        my $prefix = $_->{ prefix };
        ( $prefix eq 'SPLIT' || $prefix =~ m{\A SP}xms || $prefix =~ m{\A SPLIT}xms )
    } @$panel_types;
    
    # Convert split panel types to time types
    for my $split_pt ( @split_panel_types ) {
        push @split_time_types, {
            uid    => 'time-type-' . lc $split_pt->{ prefix },
            prefix => $split_pt->{ prefix },
            kind   => $split_pt->{ kind },
        };
    }
}

# Create timeline entries from events with split panel types
for my $event ( @$events ) {
    if ( defined $event->{ panel_type } && $event->{ panel_type } =~ m{^panel-type-(.+)}xmsi ) {
        my $prefix = uc $1;
        
        # Check if this is a split panel type
        if ( $prefix eq 'SPLIT' || $prefix =~ m{\A SP}xms || $prefix =~ m{\A SPLIT}xms ) {
            # Convert to timeline entry
            push @timeline, {
                id          => $event->{ id },
                startTime   => $event->{ start_time },
                description => $event->{ name },
                timeType    => 'time-type-' . lc $prefix,
                note        => $event->{ note },
            };
            
            # Remove this event from regular events
            $event->{ _is_timeline } = 1;
        }
    }
}

# Filter out timeline events from regular events
my @filtered_events = grep { !$_->{ _is_timeline } } @$events;

# Generate credits for display
@filtered_events = @{ Convert::Events::generate_credits( \@filtered_events, $presenters ) };

# Detect conflicts
my $conflicts = Convert::Events::detect_conflicts( \@filtered_events );
say 'Conflicts detected: ', scalar @$conflicts if @$conflicts;

# Add conflict references to events
my %event_conflicts;
for my $conflict ( @$conflicts ) {
    my $is_group_conflict = $conflict->{ type } eq 'group_presenter';
    my $details = $is_group_conflict
        ? "Group presenter overlap: " . $conflict->{ presenter } . " in multiple events"
        : $conflict->{ type } eq 'presenter'
            ? "Double-booked with: " . $conflict->{ event2 }{ name } . " (presenter: " . $conflict->{ presenter } . ")"
            : "Room conflict with: " . $conflict->{ event2 }{ name };
    
    push @{ $event_conflicts{ $conflict->{ event1 }{ id } } }, {
        type    => $conflict->{ type },
        details => $details,
        conflict_event_id => $conflict->{ event2 }{ id },
    };
    
    push @{ $event_conflicts{ $conflict->{ event2 }{ id } } }, {
        type    => $conflict->{ type },
        details => $details,
        conflict_event_id => $conflict->{ event1 }{ id },
    };
}

# Add any missing panel types that were referenced in events
my %used_prefixes;
foreach my $event (@filtered_events) {
    if (defined $event->{ panel_type } && $event->{ panel_type } =~ m{^panel-type-(.+)}xmsi) {
        my $prefix = uc $1;
        $used_prefixes{ $prefix } = 1;
    }
}

# Add missing panel types
foreach my $prefix (keys %used_prefixes) {
    my $exists = grep { $_->{ prefix } eq $prefix } @filtered_panel_types;
    next if $exists;
    
    my $kind = "${prefix} Panel";
    my $is_workshop = $prefix =~ m{W\z}xmsi ? 1 : 0;
    my $is_break = $prefix =~ m{\A BR}xmsi ? 1 : 0;
    
    push @filtered_panel_types, {
        uid         => "panel-type-" . lc $prefix,
        prefix      => $prefix,
        kind        => $kind,
        is_workshop => $is_workshop,
        is_cafe     => 0,
        is_break    => $is_break,
        is_hidden   => 0,
        is_room_hours => 0,
        color       => undef,
        bw_color    => undef,
    };
}

my $visible_rooms = [
    map {
        {
            uid        => $_->{ uid },
            short_name => $_->{ short_name },
            long_name  => $_->{ long_name },
            hotel_room => $_->{ hotel_room },
            sort_key   => $_->{ sort_key },
        }
    } grep { !$_->{ is_hidden } } @{ $rooms }
];

my $visible_types = [
    map {
        {
            uid        => $_->{ uid },
            prefix     => $_->{ prefix },
            kind       => $_->{ kind },
            isWorkshop => $_->{ is_workshop } ? JSON::true : JSON::false,
            isCafe     => $_->{ is_cafe } ? JSON::true : JSON::false,
            isBreak    => $_->{ is_break } ? JSON::true : JSON::false,
            color      => $_->{ color },
        }
    } grep { !$_->{ is_hidden } } @filtered_panel_types
];

my $json_time_types = [
    map {
        {
            uid    => $_->{ uid },
            prefix => $_->{ prefix },
            kind   => $_->{ kind },
        }
    } @split_time_types
];

my $json_presenters = [
    map {
        {
            name => $_->{ name }, 
            rank => $_->{ rank },
            groups => $_->{ groups } || [],
            is_group => $_->{ is_group } || JSON::false,
            members => $_->{ members } || [],
            always_grouped => $_->{ always_grouped } || JSON::false,
        }
    } @{ $presenters }
];

my $json_events = [
    map {
        my $event_conflict_refs = $event_conflicts{ $_->{ id } } || [];
        {
            id          => $_->{ id },
            name        => $_->{ name },
            description => $_->{ description },
            startTime   => $_->{ start_time },
            endTime     => $_->{ end_time },
            duration    => $_->{ duration },
            roomId      => $_->{ roomId },
            panelType   => $_->{ panel_type },
            cost        => $_->{ cost },
            isFree      => $_->{ is_free } ? JSON::true : JSON::false,
            isKids      => $_->{ is_kids } ? JSON::true : JSON::false,
            difficulty  => $_->{ difficulty },
            capacity    => $_->{ capacity },
            presenters  => $_->{ presenters },
            credits     => $_->{ credits },
            note        => $_->{ note },
            prereq      => $_->{ prereq },
            ticketUrl   => $_->{ ticket_url },
            isFull      => $_->{ is_full } ? JSON::true : JSON::false,
            conflicts   => $event_conflict_refs,
        }
    } @filtered_events
];

my $json_timeline = [
    map {
        {
            id          => $_->{ id },
            startTime   => $_->{ startTime },
            description => $_->{ description },
            timeType    => $_->{ timeType },
            note        => $_->{ note },
        }
    } @timeline
];

my $json_conflicts = [
    map {
        {
            type      => $_->{ type },
            presenter => $_->{ presenter } // JSON::null,
            room      => $_->{ room } // JSON::null,
            event1    => {
                id   => $_->{ event1 }{ id },
                name => $_->{ event1 }{ name },
            },
            event2    => {
                id   => $_->{ event2 }{ id },
                name => $_->{ event2 }{ name },
            },
        }
    } @$conflicts
];

# Calculate schedule bounds
my ($min_time, $max_time);
for my $event (@filtered_events) {
    if (defined $event->{ start_time }) {
        $min_time = $event->{ start_time } if !defined $min_time || $event->{ start_time } lt $min_time;
    }
    if (defined $event->{ end_time }) {
        $max_time = $event->{ end_time } if !defined $max_time || $event->{ end_time } gt $max_time;
    }
}

# Add timeline entries to bounds calculation
for my $timeline_entry (@timeline) {
    if (defined $timeline_entry->{ startTime }) {
        $min_time = $timeline_entry->{ startTime } if !defined $min_time || $timeline_entry->{ startTime } lt $min_time;
        
        # Timeline entries have implicit 30-minute duration
        my $start_dt = $timeline_entry->{ startTime };
        $start_dt =~ s/T.*//; # Extract date part
        my $end_dt = $start_dt . 'T00:30:00Z'; # Add 30 minutes
        $max_time = $end_dt if !defined $max_time || $end_dt gt $max_time;
    }
}

# Set reasonable defaults if no times found
$min_time = '2026-06-25T17:00:00Z' if !defined $min_time; # Thursday evening
$max_time = '2026-06-28T18:00:00Z' if !defined $max_time; # Sunday evening

my $output = {
    meta => {
        generated => do {
            my @t = gmtime;
            sprintf '%04d-%02d-%02dT%02d:%02d:%02dZ',
                $t[5] + 1900, $t[4] + 1, $t[3], $t[2], $t[1], $t[0];
        },
        title     => $title || 'Event Schedule',
        version   => 4,
        generator => 'schedule_to_json',
        startTime => $min_time,
        endTime   => $max_time,
    },
    timeline    => $json_timeline,
    rooms      => $visible_rooms,
    panelTypes => $visible_types,
    timeTypes  => $json_time_types,
    presenters => $json_presenters,
    events     => $json_events,
    conflicts  => $json_conflicts,
};

my $json = JSON->new->utf8->pretty->canonical->encode( $output );
write_file( $output_file, { binmode => ':raw' }, $json );
say "Written: ${output_file}";
