[#]*
*.bak
*.backup
*.o
*.old
*.orig
*.tdy
*.tmp
*.xlsx
*~
.*

# Keep some vscode files
!/.vscode
/.vscode/perl-lang

# Keep claude rules and shared settings
!/.claude
/.claude/*
!/.claude/rules
!/.claude/settings.json

# Keep windsurf rules
!/.windsurf
/.windsurf/*
!/.windsurf/rules

# Keep some config files
!/.devcontainer
!.git*[^~]
!.perlcriticrc
!.perltidyrc

# Ignore target directory
/target

# Node.js / esbuild widget build
/node_modules
/package-lock.json
/widget/*.min.js
/widget/*.min.css

# Ignore input, output and scratch directory
/scratch
/input
/output
/docs-to-be-added

# Brand config is private; only the sample is committed
/config/brand.toml
/config/brand
