[#]*
*.bak
*.backup
*.o
*.old
*.orig
*.tdy
*.tmp
*.xlsx
*~
.*

# Keep some vscode files
!/.vscode
/.vscode/perl-lang

# Keep claude rules and shared settings
!/.claude
/.claude/*
!/.claude/rules
!/.claude/workflows
!/.claude/settings.json

# Keep devin rules
!/.devin
/.devin/*
!/.devin/rules
!/.devin/workflows

# Keep some config files
!/.devcontainer
!.git*[^~]
!.perlcriticrc
!.perltidyrc
!.markdownlint.json

# Ignore target directory
/target

# Node.js / esbuild widget build
/node_modules
/package-lock.json
/widget/*.min.js
/widget/*.min.css

# Ignore input, output and scratch directory
/scratch
/input
/output
/docs-to-be-added

# Config files are private; only the sample is committed
/config/*
!/config/*[-.]sample.toml
!/config/*[-.]default.toml
!/config/sample[-.]*.toml
!/config/default[-.]*.toml

# Commit templates
next[-_]commit*.txt
next[-_]amend*.txt
!.templates/
!.templates/next[-_]commit*.txt
!.templates/next[-_]amend*.txt
